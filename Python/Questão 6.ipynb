    "resultado = 0\n",
    "contador = 1\n",
    "\n",
    "print(\"Soma de 10 números:\")\n",
    "while contador <= 10 :\n",
    "    numero = int(input(f\"Digite o {contador}º número:\"))\n",
    "    resultado += numero\n",
    "    contador += 1\n",
    "print(\"\\nO resultado da soma é:\", resultado)"
   ]
