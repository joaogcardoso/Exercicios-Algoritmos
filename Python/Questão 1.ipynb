   "source": [
    "from math import pi\n",
    "\n",
    "raio = int(input(\"Digite o valor do raio do círculo em cm:\"))\n",
    "\n",
    "area = pi * (raio ** 2)\n",
    "areaFinal = round(area, 2)\n",
    "\n",
    "print(\"O valor de PI é:\", pi)\n",
    "print(\"A área do círculo é:\", areaFinal, \"cm²\")"
   ]
  }
