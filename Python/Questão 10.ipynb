   "source": [
    "fatorial = 1\n",
    "contador = 1\n",
    "\n",
    "numero = int(input(\"Digite um número: \"))\n",
    "while contador <= numero :\n",
    "    fatorial = fatorial * contador\n",
    "    contador += 1\n",
    "print(\"O fatorial de \", numero, \" é igual a \", fatorial)"
   ]
