   ],
   "source": [
    "try:\n",
    "    numero = int(input(\"Digite um número: \"))\n",
    "\n",
    "except ValueError:\n",
    "    print(\"Entrada inválida!\")\n",
    "\n",
    "def par_ou_impar(numero):\n",
    "    if numero % 2 == 0:\n",
    "        print(f\"O número {numero} é par.\")\n",
    "    else:\n",
    "        print(f\"O número {numero} é ímpar.\")\n",
    "par_ou_impar(numero)"
   ]
  }
